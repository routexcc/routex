{
  "name": "@routexcc/core",
  "version": "1.0.0",
  "description": "Multi-chain settlement cost router engine for the x402 payment protocol",
  "license": "MIT",
  "author": "Thalaxis <opensource@thalaxis.com> (https://thalaxis.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/routexcc/routex.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/routexcc/routex#readme",
  "bugs": {
    "url": "https://github.com/routexcc/routex/issues"
  },
  "keywords": [
    "x402",
    "payment",
    "routing",
    "multi-chain",
    "micropayment",
    "ai-agent",
    "blockchain",
    "settlement"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --no-sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage"
  },
  "peerDependencies": {
    "@routexcc/cloud": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@routexcc/cloud": {
      "optional": true
    }
  },
  "devDependencies": {
    "@routexcc/cloud": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
