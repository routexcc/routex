{
  "name": "routexcc",
  "private": true,
  "description": "Multi-chain settlement cost router for the x402 payment protocol",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm --filter @routexcc/core run build && pnpm --filter @routexcc/chain-base run build && pnpm -r --filter '!@routexcc/core' --filter '!@routexcc/chain-base' run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:core": "pnpm --filter @routexcc/core test",
    "test:coverage": "pnpm -r run test:coverage",
    "test:coverage:core": "pnpm --filter @routexcc/core test:coverage",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts'",
    "clean": "pnpm -r run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "@types/node": "^20.0.0"
  }
}
